\cf2 	\'95	SVG (primary format, fully editable)\
	\'95	JPG (secondary format)\
\pard\tqr\tx100\tx260\li260\fi-260\sl324\slmult1\sb240\partightenfactor0
\cf2 	\'95	Project management:\

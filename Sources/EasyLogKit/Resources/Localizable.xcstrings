    "Changing lithology while a custom color is set can either keep your custom color or restore the default USGS fill.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Changing lithology while a custom color is set can either keep your custom color or restore the default USGS fill."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Changer la lithologie alors qu'une couleur personnalisée est définie peut conserver cette couleur ou restaurer le remplissage USGS par défaut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al cambiar la litología con un color personalizado, puedes conservar ese color o restaurar el relleno USGS predeterminado."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Canviar la litologia mentre hi ha un color personalitzat pot mantenir aquest color o restaurar el farciment USGS predeterminat."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η αλλαγή λιθολογίας όταν έχει οριστεί προσαρμοσμένο χρώμα μπορεί να διατηρήσει το χρώμα ή να επαναφέρει το προεπιλεγμένο γέμισμα USGS."
          }
        }
      }
    },
